<div class="relative min-h-screen bg-[url('bg_light_and_darkness_wide.png')] bg-cover bg-center">

  <!-- 🔹 右上ユーザーメニュー -->
  <div class="absolute top-6 right-6">
    <div class="flex gap-6">

      <% if @dark_time && @light_time %>
        <div class="flex items-center justify-center bg-stone-300/67 rounded-2xl px-4 py-3 shadow-xl w-32">
          <%= link_to "新規登録", new_light_time_path, class: "w-full text-xs text-center inline-block py-1 rounded-full bg-linear-to-r from-yellow-400 from-0% via-yellow-200 via-80% to-yellow-100 to-100% hover:from-yellow-500 hover:via-yellow-300 hover:to-yellow-200 font-semibold transition" %>
        </div>
      <% end %>

      <div class="bg-linear-to-b from-yellow-400 from-0% via-yellow-200 via-80% to-yellow-100 to-100% rounded-2xl px-4 py-3 shadow-xl w-32">

        <div class="text-sm text-center font-semibold mb-2">
          <%= current_user.name || "ユーザーA" %>
        </div>

        <%= link_to "使い方(作成中)", "#", class: "block text-xs bg-amber-800 text-white text-center rounded-full py-1 mb-2 hover:bg-amber-900 transition" %>

        <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "w-full text-xs text-center bg-red-500 text-white rounded-full py-1 hover:bg-red-600 transition" %>
      </div>
    </div>
  </div>

  <!-- 🔹 メインエリア -->
  <div class="flex items-center justify-center min-h-screen px-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-80">

      <!-- 🌑 闇側カード -->
      <%= render "dark_time", dark_time: @dark_time %>

      <!-- ☀ 光側カード -->
      <%= render "light_time", light_time: @light_time %>

    </div>
  </div>
</div>

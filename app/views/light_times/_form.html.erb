<%= form_with model: light_time, class: "space-y-8" do |f| %>
  <%= render "shared/error_messages", object: light_time %>

  <!-- 光の時間での行動 -->
  <div>
    <%= f.label :action, "光の時間での行動", class: "block text-lg mb-2" %>
    <%= f.text_field :action, class: "w-full rounded-lg bg-gray-200 border-2 border-gray-700 px-4 py-2 focus:outline-none focus:ring-4 focus:ring-blue-400" %>
  </div>

  <!-- なりたい自分 -->
  <div>
    <%= f.label :desired_self, "なりたい自分（任意）", class: "block text-lg mb-2" %>
    <%= f.text_area :desired_self, rows: 3, class: "w-full rounded-lg bg-gray-200 border-2 border-gray-700 px-4 py-2 focus:outline-none focus:ring-4 focus:ring-blue-400" %>
  </div>

  <!-- 光の時間の特徴 -->
  <div>
    <%= f.label :characteristic, "光の時間の特徴（任意）", class: "block text-lg mb-2" %>

    <p class="text-sm leading-relaxed mb-3">
      本来望んでいる行動に取り組んでいる前後や最中で
      思うことや感じること、気づいたこと
      について書いていきます。
    </p>

    <p class="text-xs mb-4">
      記入例：光の時間での行動が「読書をする」である場合<br>
      → 光の時間の特徴：<br>
      「読む前には「長い文章を読まないといけない」と強い抵抗を感じている」
    </p>

    <%= f.text_area :characteristic, rows: 4, class: "w-full rounded-lg bg-gray-200 border-2 border-gray-700 px-4 py-2 focus:outline-none focus:ring-4 focus:ring-blue-400" %>
  </div>

  <!-- ボタン -->
  <div class="flex justify-center gap-10 pt-6">
    <%= f.submit button_text, class: "#{button_class} px-8 py-2 rounded-full text-white text-lg transition duration-200 shadow-md" %>
    <%= link_to "キャンセル", cancel_path, class: "px-8 py-2 rounded-full bg-red-500 text-white text-lg hover:bg-red-600 transition duration-200 shadow-md" %>
  </div>

<% end %>
